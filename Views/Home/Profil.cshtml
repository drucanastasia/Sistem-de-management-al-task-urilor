@{
    ViewData["Title"] = "Profil";
    Layout = "_Layout";
}

<div class="profile-container">
    <h1>👤 Profilul Meu</h1>

    <div class="xp-section">
        <h2>Experiență (XP)</h2>
        <div class="xp-bar">
            <span>XP: <strong id="xpValue">0</strong></span>
            <div class="xp-progress">
                <div id="xpBar" style="width: 0%"></div>
            </div>
        </div>
        <p>Nivelul tău: <strong id="userLevel">1</strong></p>
    </div>
</div>