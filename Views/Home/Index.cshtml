@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- TOAST CONTAINER -->
<div class="toast-container" id="toastContainer"></div>

<!-- CONFIRM DIALOG -->
<div class="confirm-backdrop" id="confirmBackdrop">
  <div class="confirm-box">
    <div class="confirm-title" id="confirmTitle">Ești sigur?</div>
    <div class="confirm-msg" id="confirmMsg">Această acțiune nu poate fi anulată.</div>
    <div class="confirm-btns">
      <button class="btn btn-secondary btn-sm" onclick="closeConfirm()">Anulează</button>
      <button class="btn btn-danger btn-sm" id="confirmOkBtn">Șterge</button>
    </div>
  </div>
</div>

<!-- ADD/EDIT TASK MODAL -->
<div class="modal-backdrop" id="taskModal">
  <div class="modal">
    <div class="modal-title">
      <span id="modalTitle">Adaugă task</span>
      <button class="modal-close" onclick="closeModal('taskModal')">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg>
      </button>
    </div>
    <div class="form-group">
      <label class="form-label">Titlu task *</label>
      <input class="form-input" id="taskTitle" placeholder="Ex: Pregătit prezentare..." maxlength="100">
    </div>
    <div class="form-group">
      <label class="form-label">Descriere (opțional)</label>
      <textarea class="form-textarea" id="taskDesc" placeholder="Detalii suplimentare..."></textarea>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Categorie</label>
        <select class="form-select" id="taskCategory">
          <option value="munca">💼 Muncă</option>
          <option value="travel">✈️ Travel</option>
          <option value="timp">🎯 Timp liber</option>
          <option value="rest">😌 Rest</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Stare inițială</label>
        <select class="form-select" id="taskStatus">
          <option value="todo">To Do</option>
          <option value="prog">In Progress</option>
          <option value="done">Done</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('taskModal')">Anulează</button>
      <button class="btn btn-primary" onclick="saveTask()">
        <svg viewBox="0 0 16 16" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="3 8 7 12 13 4"/></svg>
        Salvează
      </button>
    </div>
  </div>
</div>

<!-- ADD NOTE MODAL -->
<div class="modal-backdrop" id="noteModal">
  <div class="modal">
    <div class="modal-title">
      <span id="noteModalTitle">Notiță nouă</span>
      <button class="modal-close" onclick="closeModal('noteModal')">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg>
      </button>
    </div>
    <div class="form-group">
      <label class="form-label">Conținut</label>
      <textarea class="form-textarea" id="noteContent" placeholder="Scrie notița ta aici..." style="min-height:140px"></textarea>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('noteModal')">Anulează</button>
      <button class="btn btn-primary" onclick="saveNote()">Salvează</button>
    </div>
  </div>
</div>

<!-- ADD CALENDAR EVENT MODAL -->
<div class="modal-backdrop" id="calModal">
  <div class="modal">
    <div class="modal-title">
      <span>Adaugă eveniment</span>
      <button class="modal-close" onclick="closeModal('calModal')">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/></svg>
      </button>
    </div>
    <div class="form-group">
      <label class="form-label">Titlu eveniment *</label>
      <input class="form-input" id="calTitle" placeholder="Ex: Zbor Barcelona...">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Data</label>
        <input class="form-input" id="calDate" type="date">
      </div>
      <div class="form-group">
        <label class="form-label">Culoare</label>
        <select class="form-select" id="calColor">
          <option value="purple">🟣 Violet</option>
          <option value="blue">🔵 Albastru</option>
          <option value="green">🟢 Verde</option>
          <option value="amber">🟡 Galben</option>
          <option value="red">🔴 Roșu</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('calModal')">Anulează</button>
      <button class="btn btn-primary" onclick="saveCalEvent()">Salvează</button>
    </div>
  </div>
</div>

<!-- ================== AUTH SCREEN ================== -->
<div id="authScreen" class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="logo-mark">
        <svg viewBox="0 0 18 18"><polyline points="3 10 7 14 15 6"/></svg>
      </div>
      <span style="font-size:18px;font-weight:700;">Task<span style="color:var(--purple)">Management</span></span>
    </div>

    <!-- LOGIN FORM -->
    <div id="loginForm">
      <div class="auth-title">Bun venit înapoi!</div>
      <div class="auth-sub">Autentifică-te în contul tău</div>
      <div class="auth-error" id="loginError"></div>
      <div class="form-group">
        <label class="form-label">Nume utilizator</label>
        <input class="form-input" id="loginUser" placeholder="utilizator" autocomplete="username">
      </div>
      <div class="form-group">
        <label class="form-label">Parolă</label>
        <input class="form-input" id="loginPass" type="password" placeholder="••••••••" autocomplete="current-password">
      </div>
      <button class="btn btn-primary" style="width:100%;justify-content:center;margin-top:4px" onclick="doLogin()">Autentificare</button>
      <div class="auth-switch">Nu ai cont? <a onclick="switchAuth('register')">Înregistrează-te</a></div>
    </div>

    <!-- REGISTER FORM -->
    <div id="registerForm" style="display:none">
      <div class="auth-title">Creează un cont</div>
      <div class="auth-sub">Începe să-ți gestionezi taskurile</div>
      <div class="auth-error" id="registerError"></div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Prenume</label>
          <input class="form-input" id="regFirst" placeholder="Ana">
        </div>
        <div class="form-group">
          <label class="form-label">Nume</label>
          <input class="form-input" id="regLast" placeholder="Popescu">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Nume utilizator *</label>
        <input class="form-input" id="regUser" placeholder="ana.popescu">
      </div>
      <div class="form-group">
        <label class="form-label">Parolă *</label>
        <input class="form-input" id="regPass" type="password" placeholder="minim 6 caractere">
      </div>
      <button class="btn btn-primary" style="width:100%;justify-content:center;margin-top:4px" onclick="doRegister()">Înregistrare</button>
      <div class="auth-switch">Ai deja cont? <a onclick="switchAuth('login')">Autentifică-te</a></div>
    </div>
  </div>
</div>

<!-- ================== MAIN APP ================== -->
<div id="mainApp" class="app" style="display:none">
  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="logo-mark">
        <svg viewBox="0 0 18 18"><polyline points="3 10 7 14 15 6"/></svg>
      </div>
      <div class="logo-text">Task<span>Management</span></div>
    </div>
    <div class="sidebar-nav">
      <button class="nav-item active" onclick="navigate('tasks')" id="nav-tasks">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1.5" y="1.5" width="5" height="5" rx="1.2"/><rect x="9.5" y="1.5" width="5" height="5" rx="1.2"/><rect x="1.5" y="9.5" width="5" height="5" rx="1.2"/><rect x="9.5" y="9.5" width="5" height="5" rx="1.2"/></svg>
        Taskuri
      </button>
      <button class="nav-item" onclick="navigate('calendar')" id="nav-calendar">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1.5" y="2.5" width="13" height="11" rx="1.8"/><line x1="1.5" y1="6.5" x2="14.5" y2="6.5"/><line x1="5" y1="1" x2="5" y2="4"/><line x1="11" y1="1" x2="11" y2="4"/></svg>
        Calendar
      </button>
      <button class="nav-item" onclick="navigate('notes')" id="nav-notes">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2h10a1 1 0 0 1 1 1v10l-3 3H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/><line x1="5" y1="6" x2="11" y2="6"/><line x1="5" y1="9" x2="9" y2="9"/></svg>
        Notițe
      </button>
      <div class="nav-divider"></div>
      <button class="nav-item" onclick="navigate('profile')" id="nav-profile">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="5.5" r="3"/><path d="M2 14c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5"/></svg>
        Profil
      </button>
    </div>
    <div class="sidebar-user">
      <div class="user-card">
        <div class="avatar" id="sidebarAvatar">LA</div>
        <div class="user-info">
          <div class="user-name" id="sidebarName">Luca Anastasia</div>
          <div class="user-level">
            <span class="level-badge" id="sidebarLevel">Niv.1</span>
            <span id="sidebarXpText">0 XP</span>
          </div>
          <div class="xp-bar"><div class="xp-fill" id="sidebarXpFill" style="width:0%"></div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">
    <!-- TOPBAR -->
    <div class="topbar">
      <div class="search-wrap">
        <svg class="search-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="7" cy="7" r="4.5"/><line x1="10.5" y1="10.5" x2="14" y2="14"/></svg>
        <input class="search-input" id="searchInput" placeholder="Caută taskuri..." oninput="searchTasks(this.value)">
      </div>
      <div class="topbar-actions">
        <div class="icon-btn" onclick="toggleTheme()" title="Schimbă tema">
          <svg viewBox="0 0 16 16"><path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.3 3.3l1.4 1.4M11.3 11.3l1.4 1.4M3.3 12.7l1.4-1.4M11.3 4.7l1.4-1.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/><circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.8" fill="none"/></svg>
        </div>
        <div class="icon-btn" id="notifBtn" title="Notificări">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 1a5 5 0 0 1 5 5c0 4 1.5 5.5 1.5 5.5H1.5S3 10 3 6a5 5 0 0 1 5-5z"/><path d="M6.5 13.5a1.5 1.5 0 0 0 3 0"/></svg>
          <div class="notif-dot" id="notifDot" style="display:none"></div>
        </div>
        <div class="icon-btn" onclick="doLogout()" title="Ieșire">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2H3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h3"/><polyline points="10 11 14 8 10 5"/><line x1="14" y1="8" x2="6" y2="8"/></svg>
        </div>
      </div>
    </div>

    <!-- PAGES -->
    <div class="content">

      <!-- ===== TASKS PAGE ===== -->
      <div class="page active" id="page-tasks">
        <div class="page-header">
          <div>
            <div class="page-title">Tabloul meu de taskuri</div>
            <div class="page-subtitle" id="taskSubtitle">0 taskuri active</div>
          </div>
          <button class="btn btn-primary" onclick="openAddTask()">
            <svg viewBox="0 0 16 16" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" width="14" height="14"><line x1="8" y1="2" x2="8" y2="14"/><line x1="2" y1="8" x2="14" y2="8"/></svg>
            Adaugă task
          </button>
        </div>

        <div class="stats-row" id="taskStats">
          <div class="stat-card"><div class="label">Total taskuri</div><div class="value" id="statTotal">0</div><div class="sub" id="statSub">—</div></div>
          <div class="stat-card purple"><div class="label">XP acumulat</div><div class="value" id="statXp">0</div><div class="sub" id="statLevel">Nivel 1</div></div>
          <div class="stat-card green"><div class="label">Finalizate</div><div class="value" id="statDone">0</div><div class="sub" id="statToday">—</div></div>
        </div>

        <div class="filter-row">
          <div class="chip active" onclick="filterTasks('all',this)">Toate</div>
          <div class="chip" onclick="filterTasks('munca',this)">💼 Muncă</div>
          <div class="chip" onclick="filterTasks('travel',this)">✈️ Travel</div>
          <div class="chip" onclick="filterTasks('timp',this)">🎯 Timp liber</div>
          <div class="chip" onclick="filterTasks('rest',this)">😌 Rest</div>
        </div>

        <div class="kanban" id="kanban">
          <div class="kanban-col" id="col-todo" ondragover="dragOver(event,'todo')" ondragleave="dragLeave(event)" ondrop="drop(event,'todo')">
            <div class="col-header"><span class="col-label">To Do</span><span class="col-badge todo" id="badge-todo">0</span></div>
            <div id="list-todo"></div>
          </div>
          <div class="kanban-col" id="col-prog" ondragover="dragOver(event,'prog')" ondragleave="dragLeave(event)" ondrop="drop(event,'prog')">
            <div class="col-header"><span class="col-label">In Progress</span><span class="col-badge prog" id="badge-prog">0</span></div>
            <div id="list-prog"></div>
          </div>
          <div class="kanban-col" id="col-done" ondragover="dragOver(event,'done')" ondragleave="dragLeave(event)" ondrop="drop(event,'done')">
            <div class="col-header"><span class="col-label">Done</span><span class="col-badge done" id="badge-done">0</span></div>
            <div id="list-done"></div>
          </div>
        </div>
      </div>

      <!-- ===== CALENDAR PAGE ===== -->
      <div class="page" id="page-calendar">
        <div class="page-header">
          <div><div class="page-title">Calendar</div><div class="page-subtitle">Planifică-ți activitățile</div></div>
          <button class="btn btn-primary" onclick="openCalModal()">
            <svg viewBox="0 0 16 16" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" width="14" height="14"><line x1="8" y1="2" x2="8" y2="14"/><line x1="2" y1="8" x2="14" y2="8"/></svg>
            Adaugă eveniment
          </button>
        </div>
        <div class="cal-nav">
          <button class="btn btn-secondary btn-sm" onclick="calPrev()">←</button>
          <div class="cal-month" id="calMonthTitle">—</div>
          <button class="btn btn-secondary btn-sm" onclick="calNext()">→</button>
        </div>
        <div class="cal-grid" id="calGrid"></div>
        <div class="cal-events-section">
          <div class="info-section-title" style="margin-bottom:12px" id="calEventsTitle">Toate evenimentele</div>
          <div id="calEventsList"></div>
        </div>
      </div>

      <!-- ===== NOTES PAGE ===== -->
      <div class="page" id="page-notes">
        <div class="page-header">
          <div><div class="page-title">Notițe personale</div><div class="page-subtitle">Gânduri, idei, memo-uri</div></div>
          <button class="btn btn-primary" onclick="openAddNote()">
            <svg viewBox="0 0 16 16" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" width="14" height="14"><line x1="8" y1="2" x2="8" y2="14"/><line x1="2" y1="8" x2="14" y2="8"/></svg>
            Notiță nouă
          </button>
        </div>
        <div class="notes-grid" id="notesGrid"></div>
      </div>

      <!-- ===== PROFILE PAGE ===== -->
      <div class="page" id="page-profile">
        <div class="page-header">
          <div><div class="page-title">Profilul meu</div><div class="page-subtitle">Statistici și setări</div></div>
        </div>
        <div class="profile-grid">
          <div>
            <div class="profile-card">
              <div class="profile-avatar" id="profileAvatarBig">LA</div>
              <div class="profile-name" id="profileName">Luca Anastasia</div>
              <div class="profile-email" id="profileEmail">utilizator</div>
              <div class="profile-level-big">
                <span class="profile-level-num" id="profileLevelNum">1</span>
                <span class="profile-level-label">Nivel curent</span>
              </div>
              <div class="profile-xp-bar">
                <div class="profile-xp-text">
                  <span id="profileXpCur">0 XP</span>
                  <span id="profileXpNext">până la nivel 2</span>
                </div>
                <div class="profile-xp-track"><div class="profile-xp-fill" id="profileXpFill" style="width:0%"></div></div>
              </div>
              <div class="stats-grid">
                <div class="stat-mini"><div class="num" id="pStatDone">0</div><div class="lbl">Finalizate</div></div>
                <div class="stat-mini"><div class="num" id="pStatTotal">0</div><div class="lbl">Total</div></div>
                <div class="stat-mini"><div class="num" id="pStatXp" style="color:var(--purple)">0</div><div class="lbl">XP total</div></div>
                <div class="stat-mini"><div class="num" id="pStatLevel" style="color:var(--purple)">1</div><div class="lbl">Nivel max</div></div>
              </div>
            </div>
          </div>
          <div class="info-panel">
            <div class="info-section-title">Schimbă tema</div>
            <div class="theme-row" style="margin-bottom:24px">
              <div class="theme-opt active" id="themeLight" onclick="setTheme('light')">☀️ Luminoasă</div>
              <div class="theme-opt" id="themeDark" onclick="setTheme('dark')">🌙 Întunecată</div>
            </div>
            <div class="info-section-title">Export date</div>
            <div class="export-row">
              <button class="btn btn-secondary" onclick="exportJSON()">⬇️ Export JSON</button>
              <button class="btn btn-secondary" onclick="exportTXT()">⬇️ Export Text</button>
            </div>
            <div class="import-section">
              <div class="info-section-title">Import date (JSON)</div>
              <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                <input type="file" id="importFile" accept=".json" style="display:none" onchange="importJSON(this)">
                <button class="btn btn-secondary" onclick="document.getElementById('importFile').click()">⬆️ Alege fișier JSON</button>
                <span style="font-size:12px;color:var(--text3)">Fișierul va fi adăugat peste taskurile existente</span>
              </div>
            </div>
            <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--border)">
              <div class="info-section-title">Cont</div>
              <button class="btn btn-danger" onclick="doLogout()">Ieșire din cont</button>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /mainApp -->
