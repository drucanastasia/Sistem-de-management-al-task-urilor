@{
    ViewData["Title"] = "Task-uri - " + Context.Request.Query["category"];
    Layout = "_Layout";
    var category = Context.Request.Query["category"].ToString();
}

<div class="task-container">
    <!-- Header cu categoria curentă -->
    <header class="task-header">
        <a href="/Home/Index" class="back-link">← Înapoi la meniu</a>
        <h1 id="pageTitle">Task-uri: @category?.ToUpper()</h1>
        <div class="quote" id="quoteTask">
            @GetQuoteForCategory(category)
        </div>
    </header>

    <!-- XP Bar -->
    <div class="xp-bar">
        <span>XP: <strong id="userXp">0</strong></span>
        <div class="xp-progress">
            <div id="xpFill" style="width: 0%"></div>
        </div>
    </div>

    <!-- Formular adăugare task -->
    <div class="form-section">
        <input type="text" id="taskInput" placeholder="Scrie un task..." autocomplete="off">
        <button id="addBtn">Adaugă</button>
    </div>

    <!-- Căutare -->
    <div class="search-section">
        <input type="text" id="searchInput" placeholder="Caută task...">
    </div>

    <!-- Cele 3 coloane de task-uri -->
    <div class="stages">
        <!-- To Do -->
        <div class="stage" id="todo">
            <div class="stage-header">
                <span class="stage-icon">📋</span>
                <h2>To Do</h2>
                <input type="checkbox" class="select-all" data-column="todo">
            </div>
            <div class="tasks-list"></div>
        </div>

        <!-- In Progress -->
        <div class="stage" id="progress">
            <div class="stage-header">
                <span class="stage-icon">🔄</span>
                <h2>In Progress</h2>
                <input type="checkbox" class="select-all" data-column="progress">
            </div>
            <div class="tasks-list"></div>
        </div>

        <!-- Done -->
        <div class="stage" id="done">
            <div class="stage-header">
                <span class="stage-icon">✅</span>
                <h2>Done</h2>
                <input type="checkbox" class="select-all" data-column="done">
            </div>
            <div class="tasks-list"></div>
        </div>
    </div>

    <!-- Statistici (Chart) -->
    <div class="stats">
        <canvas id="chart" width="250" height="250"></canvas>
        <div class="percent" id="percent">0%</div>
    </div>

    <!-- Notițe Personale -->
    <section class="notes-canvas">
        <h3>📝 Notițe Personale</h3>
        <div class="note-paper">
            <textarea id="personalNotes" placeholder="Scrie aici notițe personale..."></textarea>
        </div>
    </section>

    <!-- Export / Import -->
    <div class="export-import">
        <select id="exportFormat">
            <option value="json">.json</option>
            <option value="csv">.csv</option>
            <option value="txt">.txt</option>
        </select>
        <button id="exportBtn">💾 Export</button>

        <select id="importFormat">
            <option value="json">.json</option>
            <option value="csv">.csv</option>
            <option value="txt">.txt</option>
        </select>
        <button id="importBtn">📥 Import</button>
    </div>
</div>

@functions {
    // Funcție helper pentru citate pe categorii
    private string GetQuoteForCategory(string cat)
    {
        return cat switch
        {
            "university" => "Cunoașterea este putere — organizeaz-o!",
            "work" => "Productivitatea începe cu planificarea.",
            "travel" => "Fiecare drum începe cu un pas.",
            "personal" => "Planifică-ți ziua, trăiește-ți visul.",
            _ => "Organizează-ți viața, pas cu pas."
        };
    }
}

@section Scripts {
    <script>
        // === Variabile globale ===
        const currentCategory = '@Context.Request.Query["category"]';
        const storageKey = 'tasks_' + currentCategory;
        let tasks = JSON.parse(localStorage.getItem(storageKey)) || [];
        let userXp = parseInt(localStorage.getItem('userXp')) || 0;
        let selectedTaskIds = new Set();
        let searchTerm = "";
        let chartInstance = null;

        // === Inițializare ===
        document.addEventListener('DOMContentLoaded', () => {
            initChart();
            render();
            updateXpDisplay();
            loadNotes();
            setupEventListeners();
        });

        // === Render task-uri ===
        function render() {
            ['todo', 'progress', 'done'].forEach(status => {
                const list = document.querySelector(`#${status} .tasks-list`);
                if (!list) return;
                list.innerHTML = '';

                tasks.filter(t => t.status === status)
                    .filter(t => !searchTerm || t.text.toLowerCase().includes(searchTerm))
                    .forEach((task, index) => {
                        const el = createTaskElement(task);
                        list.appendChild(el);
                    });
            });
            updateChart();
            updateSelectAllCheckboxes();
        }

        function createTaskElement(task) {
            const div = document.createElement('div');
            div.className = `task ${task.status}`;
            div.dataset.id = task.id;

            if (selectedTaskIds.has(task.id)) {
                div.classList.add('selected');
            }

            div.innerHTML = `
                <span class="task-text">${escapeHtml(task.text)}</span>
                <div class="task-actions">
                    <button class="task-btn edit" title="Editează">✏️</button>
                    <button class="task-btn delete" title="Șterge">🗑️</button>
                </div>
            `;

            // Click pe task → mută statusul
            div.addEventListener('click', (e) => {
                if (e.target.closest('button')) return;

                if (selectedTaskIds.has(task.id)) {
                    selectedTaskIds.delete(task.id);
                    div.classList.remove('selected');
                    updateSelectAllCheckboxes();
                    return;
                }

                // Mută statusul
                if (task.status === 'todo') task.status = 'progress';
                else if (task.status === 'progress') {
                    task.status = 'done';
                    addXp(10);
                }
                saveTasks();
                render();
            });

            // Buton Edit
            div.querySelector('.edit').onclick = (e) => {
                e.stopPropagation();
                const newText = prompt('Editează task-ul:', task.text);
                if (newText && newText.trim()) {
                    task.text = newText.trim();
                    saveTasks();
                    render();
                }
            };

            // Buton Delete
            div.querySelector('.delete').onclick = (e) => {
                e.stopPropagation();
                if (confirm('Ștergi acest task?')) {
                    tasks = tasks.filter(t => t.id !== task.id);
                    selectedTaskIds.delete(task.id);
                    saveTasks();
                    render();
                }
            };

            return div;
        }

        // === Adăugare task ===
        function addTask() {
            const input = document.getElementById('taskInput');
            const text = input.value.trim();
            if (!text) return;

            tasks.push({
                id: Date.now(),
                text: text,
                status: 'todo'
            });

            input.value = '';
            saveTasks();
            render();
        }

        // === XP System ===
        function addXp(amount) {
            userXp += amount;
            localStorage.setItem('userXp', userXp);
            updateXpDisplay();
            checkUnlocks();
        }

        function updateXpDisplay() {
            const xpEl = document.getElementById('userXp');
            const fillEl = document.getElementById('xpFill');
            if (!xpEl || !fillEl) return;

            xpEl.textContent = userXp;
            const progress = (userXp % 100);
            fillEl.style.width = progress + '%';
        }

        function checkUnlocks() {
            if (userXp >= 50 && !localStorage.getItem('unlocked_themes')) {
                alert('🔓 Ai deblocat Teme Personalizate!');
                localStorage.setItem('unlocked_themes', 'true');
            }
        }

        // === Chart ===
        function initChart() {
            const canvas = document.getElementById('chart');
            if (!canvas) return;

            chartInstance = new Chart(canvas, {
                type: 'doughnut',
                data: {
                    labels: ['To Do', 'In Progress', 'Done'],
                    datasets: [{
                        data: [0, 0, 0],
                        backgroundColor: ['#ffcc00', '#36a2eb', '#4caf50']
                    }]
                },
                options: {
                    plugins: { legend: { display: false } },
                    cutout: '70%',
                    responsive: true
                }
            });
        }

        function updateChart() {
            if (!chartInstance) return;
            const counts = {
                todo: tasks.filter(t => t.status === 'todo').length,
                progress: tasks.filter(t => t.status === 'progress').length,
                done: tasks.filter(t => t.status === 'done').length
            };
            chartInstance.data.datasets[0].data = [counts.todo, counts.progress, counts.done];
            chartInstance.update();

            const total = tasks.length;
            const percent = total ? Math.round(counts.done / total * 100) : 0;
            document.getElementById('percent').textContent = percent + '%';
        }

        // === Select All ===
        function updateSelectAllCheckboxes() {
            ['todo', 'progress', 'done'].forEach(col => {
                const tasksInCol = tasks.filter(t => t.status === col);
                const selectedInCol = tasksInCol.filter(t => selectedTaskIds.has(t.id));
                const checkbox = document.querySelector(`.select-all[data-column="${col}"]`);

                if (checkbox) {
                    if (selectedInCol.length === 0) {
                        checkbox.checked = false;
                        checkbox.indeterminate = false;
                    } else if (selectedInCol.length === tasksInCol.length) {
                        checkbox.checked = true;
                        checkbox.indeterminate = false;
                    } else {
                        checkbox.checked = false;
                        checkbox.indeterminate = true;
                    }
                }
            });
        }

        document.querySelectorAll('.select-all').forEach(cb => {
            cb.addEventListener('change', function() {
                const col = this.dataset.column;
                const checked = this.checked;

                tasks.filter(t => t.status === col).forEach(t => {
                    if (checked) selectedTaskIds.add(t.id);
                    else selectedTaskIds.delete(t.id);
                });

                render();
            });
        });

        // === Utilitare ===
        function saveTasks() {
            localStorage.setItem(storageKey, JSON.stringify(tasks));
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // === Notițe ===
        function loadNotes() {
            const notes = document.getElementById('personalNotes');
            if (notes) {
                notes.value = localStorage.getItem('notes_' + currentCategory) || '';
                notes.addEventListener('input', () => {
                    localStorage.setItem('notes_' + currentCategory, notes.value);
                });
            }
        }

        // === Event Listeners ===
        function setupEventListeners() {
            document.getElementById('addBtn')?.addEventListener('click', addTask);
            document.getElementById('taskInput')?.addEventListener('keypress', e => {
                if (e.key === 'Enter') addTask();
            });
            document.getElementById('searchInput')?.addEventListener('input', e => {
                searchTerm = e.target.value.toLowerCase();
                render();
            });
            document.getElementById('exportBtn')?.addEventListener('click', exportTasks);
            document.getElementById('importBtn')?.addEventListener('click', importTasks);
        }

        // === Export/Import (simplificat) ===
        function exportTasks() {
            const format = document.getElementById('exportFormat').value;
            const data = JSON.stringify(tasks, null, 2);
            const blob = new Blob([data], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `tasks_${currentCategory}.${format}`;
            a.click();
            URL.revokeObjectURL(url);
        }

        function importTasks() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = e => {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = event => {
                    try {
                        tasks = JSON.parse(event.target.result);
                        saveTasks();
                        render();
                        alert('Task-uri importate!');
                    } catch (err) {
                        alert('Eroare la import: ' + err.message);
                    }
                };
                reader.readAsText(file);
            };
            input.click();
        }
    </script>
}